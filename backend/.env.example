# ─── Required ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Supabase project URL (found in: Project → Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service_role key — grants full DB access, keep this secret!
# Found in: Project → Settings → API → Project API keys → service_role
SUPABASE_KEY=your-service-role-key-here

# ─── Optional ─────────────────────────────────────────────────────────────────

# "development" or "production"
APP_ENV=development

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins (override the defaults in config.py)
# CORS_ORIGINS=http://localhost:3000,https://tasks-manager-xi.vercel.app
